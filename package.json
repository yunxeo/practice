{
  "name": "profiler-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/link-mobile-deps.js",
    "dev:api": "npm run --workspace=apps/api dev",
    "dev:mobile": "npm run --workspace=apps/mobile start",
    "build:api": "npm run --workspace=apps/api build",
    "build:shared": "npm run --workspace=packages/shared build"
  }
}
